<web-app>
  <filter>
    <filter-name>struts2</filter-name>
    <filter-class>org.apache.struts2.dispatcher.filter.StrutsPrepareAndExecuteFilter</filter-class>
  </filter>
  <filter>
    <filter-name>dynamicMapping</filter-name>
    <filter-class>com.example.web.DynamicMappingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>struts2</filter-name>
    <url-pattern>*.action</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>dynamicMapping</filter-name>
    <url-pattern>*.dyn</url-pattern>
  </filter-mapping>
</web-app>
