<beans xmlns="http://www.springframework.org/schema/beans" xmlns:p="http://www.springframework.org/schema/p">
  <bean class="org.springframework.web.servlet.handler.SimpleUrlHandlerMapping">
    <property name="mappings">
      <props>
        <prop key="/sample/*.as">sampleAction</prop>
      </props>
    </property>
  </bean>

  <bean
    id="sampleAction"
    class="com.example.legacy.web.SampleAction"
    p:methodNameResolver-ref="sampleActionResolver" />

  <bean id="sampleActionResolver" class="org.springframework.web.servlet.mvc.multiaction.PropertiesMethodNameResolver">
    <property name="mappings">
      <props>
        <prop key="/sample/list.as">getSampleList</prop>
        <prop key="/sample/view.as">getSampleView</prop>
      </props>
    </property>
  </bean>

  <bean class="org.springframework.web.servlet.view.InternalResourceViewResolver">
    <property name="prefix" value="/WEB-INF/views/" />
    <property name="suffix" value=".jsp" />
  </bean>
</beans>
